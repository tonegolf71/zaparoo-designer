{
  "name": "nfc-retro-label-printer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "cp ./src/utils/blob-stream.js ./node_modules/blob-stream/",
    "build": "yarn prebuild && tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "make-logos": "node scripts/logos-data.mjs && prettier --write ./src/assets/logos/*.ts",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.x",
    "@mui/material": "7.x",
    "@netlify/functions": "^2.6.0",
    "@types/blob-stream": "^0.1.33",
    "@types/pdfkit": "^0.13.3",
    "@types/three": "^0.168.0",
    "@uiw/react-color-compact": "^2.0.5",
    "blob-stream": "^0.1.3",
    "client-zip": "^2.4.4",
    "fabric": "^6.9.0",
    "pdfkit": "0.17.x",
    "react": "^19.x",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.x",
    "react-intersection-observer": "^9.16.0",
    "react-router-dom": "^7.12.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "5.x",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "3.1.1",
    "typescript": "^5.5.4",
    "vite": "7.x",
    "vitest": "^4.0.18"
  }
}
